{
    "name": "${localWorkspaceFolderBasename}-dev",
    "image": "127.0.0.1:5000/javascript-dev:1.0.4",
    "remoteUser": "developer",
    "containerUser": "developer",
    "updateRemoteUserUID": true,
    "runArgs": [
        "--name=${localWorkspaceFolderBasename}-dev",
        "--userns=keep-id",
        "--security-opt=no-new-privileges"
    ],
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
    "mounts": [
        // ~/my/kb
        "type=bind,source=${localEnv:HOME}/my/kb,target=/home/developer/kb",
        // pnpm
        "type=volume,source=javascript-pnpm-store,target=/home/developer/.local/share/pnpm/store"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "davidanson.vscode-markdownlint",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode"
            ]
        }
    }
}